# App
APP_URL=http://localhost:3000
API_URL=http://localhost:3001

# Admin — comma-separated GitHub numeric IDs that get auto-elevated on login.
# Keyed by ID (not username) so reusing a deleted username can't re-grant
# admin privileges. Find an ID via https://api.github.com/users/<username>.
ADMIN_GITHUB_IDS=

# Database
DATABASE_URL=postgresql://ruleshub:ruleshub@localhost:5432/ruleshub

# Auth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3001/v1/auth/github/callback

JWT_SECRET=

# Storage (MinIO / S3-compatible)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=ruleshub
MINIO_SECRET_KEY=ruleshub_secret
MINIO_BUCKET=ruleshub-packages

