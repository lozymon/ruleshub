{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.ts$": "ts-jest"
  },
  "collectCoverageFrom": ["src/**/*.service.ts"],
  "coverageThreshold": {
    "global": {
      "lines": 80
    }
  },
  "testEnvironment": "node",
  "globalSetup": "./test/global-setup.ts",
  "setupFiles": ["./test/env-setup.ts"]
}
