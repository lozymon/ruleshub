generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OwnerType {
  user
  org
}

enum OrgRole {
  owner
  admin
  member
}

model User {
  id         String   @id @default(cuid())
  githubId   String   @unique
  username   String   @unique
  avatarUrl  String?
  bio        String?
  verified   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  packages   Package[]
  orgMembers OrgMember[]
  stars      Star[]
}

model Organisation {
  id          String   @id @default(cuid())
  slug        String   @unique
  displayName String
  avatarUrl   String?
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members  OrgMember[]
  packages Package[]
}

model OrgMember {
  org    Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId  String
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  role   OrgRole      @default(member)

  @@id([orgId, userId])
}

model Package {
  id             String    @id @default(cuid())
  namespace      String
  name           String
  type           String
  description    String
  tags           String[]
  projectTypes   String[]
  supportedTools String[]
  isPrivate      Boolean   @default(false)
  totalDownloads Int       @default(0)
  stars          Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  ownerType  OwnerType
  ownerUserId  String?
  ownerOrgId   String?
  owner        User?         @relation(fields: [ownerUserId], references: [id])
  org          Organisation? @relation(fields: [ownerOrgId], references: [id])
  forkedFrom Package?      @relation("Forks", fields: [forkedFromId], references: [id])
  forkedFromId String?
  forks      Package[]     @relation("Forks")

  versions      PackageVersion[]
  starredBy     Star[]
  githubImport  GitHubImport?

  @@unique([namespace, name])
  @@index([namespace])
  @@index([type])
  @@index([tags])
}

model PackageVersion {
  id           String   @id @default(cuid())
  package      Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)
  packageId    String
  version      String
  manifestJson Json
  storageKey   String
  downloads    Int      @default(0)
  yanked       Boolean  @default(false)
  publishedAt  DateTime @default(now())

  @@unique([packageId, version])
  @@index([packageId])
}

model Star {
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  package   Package @relation(fields: [packageId], references: [id], onDelete: Cascade)
  packageId String

  @@id([userId, packageId])
}

model GitHubImport {
  id           String   @id @default(cuid())
  package      Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)
  packageId    String   @unique
  repoUrl      String
  lastSyncedAt DateTime?
  webhookId    String?
  createdAt    DateTime @default(now())
}
