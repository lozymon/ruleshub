{
  "name": "@ruleshub/kit",
  "version": "0.1.0",
  "description": "TypeScript helpers for reading, building, and validating RulesHub manifests",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
