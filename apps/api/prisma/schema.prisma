generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OwnerType {
  user
  org
}

enum OrgRole {
  owner
  admin
  member
}

model User {
  id         String   @id @default(cuid())
  githubId   String   @unique
  username   String   @unique
  avatarUrl  String?
  bio        String?
  verified   Boolean  @default(false)
  blocked    Boolean  @default(false)
  isAdmin    Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  packages     Package[]
  orgMembers   OrgMember[]
  stars        Star[]
  collections  Collection[]
  comments     Comment[]
  apiKeys      ApiKey[]
  webhooks     Webhook[]
}

model Organisation {
  id          String   @id @default(cuid())
  slug        String   @unique
  displayName String
  avatarUrl   String?
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members  OrgMember[]
  packages Package[]
}

model OrgMember {
  org    Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId  String
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  role   OrgRole      @default(member)

  @@id([orgId, userId])
}

model Package {
  id             String    @id @default(cuid())
  namespace      String
  name           String
  type           String
  description    String
  tags           String[]
  projectTypes   String[]
  supportedTools String[]
  isPrivate      Boolean   @default(false)
  totalDownloads Int       @default(0)
  stars          Int       @default(0)
  qualityScore   Int       @default(0)
  hasReadme      Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  ownerType  OwnerType
  ownerUserId  String?
  ownerOrgId   String?
  owner        User?         @relation(fields: [ownerUserId], references: [id])
  org          Organisation? @relation(fields: [ownerOrgId], references: [id])
  forkedFrom Package?      @relation("Forks", fields: [forkedFromId], references: [id])
  forkedFromId String?
  forks      Package[]     @relation("Forks")

  versions         PackageVersion[]
  starredBy        Star[]
  githubImport     GitHubImport?
  collectionItems  CollectionItem[]
  comments         Comment[]
  webhooks         Webhook[]
  packDependencies PackageDependency[] @relation("PackDeps")
  depOf            PackageDependency[] @relation("DepOf")

  @@unique([namespace, name])
  @@index([namespace])
  @@index([type])
  @@index([tags])
}

model PackageDependency {
  packId       String
  depId        String
  versionRange String
  pack         Package @relation("PackDeps", fields: [packId], references: [id], onDelete: Cascade)
  dep          Package @relation("DepOf",   fields: [depId],  references: [id], onDelete: Restrict)

  @@id([packId, depId])
  @@index([depId])
}

model PackageVersion {
  id           String   @id @default(cuid())
  package      Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)
  packageId    String
  version      String
  manifestJson Json
  storageKey   String
  // Hex-encoded SHA-256 of the stored zip artifact. Computed at publish
  // time and surfaced via the download envelope so clients can verify
  // they got the bytes the registry intended to ship. Nullable for rows
  // published before this column existed; new rows are always set.
  sha256       String?
  changelog    String?
  downloads    Int      @default(0)
  yanked       Boolean  @default(false)
  publishedAt  DateTime @default(now())

  @@unique([packageId, version])
  @@index([packageId])
}

model Star {
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  package   Package @relation(fields: [packageId], references: [id], onDelete: Cascade)
  packageId String

  @@id([userId, packageId])
}

model GitHubImport {
  id            String    @id @default(cuid())
  package       Package   @relation(fields: [packageId], references: [id], onDelete: Cascade)
  packageId     String    @unique
  repoUrl       String
  webhookSecret String
  lastSyncedAt  DateTime?
  createdAt     DateTime  @default(now())
}

model Collection {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  slug        String
  title       String
  description String?
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items       CollectionItem[]

  @@unique([userId, slug])
  @@index([userId])
}

model CollectionItem {
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  collectionId String
  package      Package    @relation(fields: [packageId], references: [id], onDelete: Cascade)
  packageId    String
  addedAt      DateTime   @default(now())

  @@id([collectionId, packageId])
}

model Comment {
  id        String   @id @default(cuid())
  package   Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)
  packageId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([packageId])
}

model ApiKey {
  id         String    @id @default(cuid())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  name       String
  keyHash    String    @unique
  prefix     String
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
}

model EmailSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model Webhook {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  package   Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)
  packageId String
  url       String
  secret    String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  deliveries WebhookDelivery[]

  @@unique([userId, packageId, url])
  @@index([packageId])
  @@index([userId])
}

model WebhookDelivery {
  id          String   @id @default(cuid())
  webhook     Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  webhookId   String
  event       String
  payload     Json
  statusCode  Int?
  success     Boolean
  attemptedAt DateTime @default(now())

  @@index([webhookId])
}
